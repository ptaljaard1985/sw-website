---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
import TestimonialsCarousel from '../components/TestimonialsCarousel.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "About You — Simple Wealth",
  "description": "Whether you're building wealth, planning for retirement, or thinking about your legacy, it helps to have a trusted adviser by your side.",
  "publisher": {
    "@type": "Organization",
    "name": "Simple Wealth",
    "url": "https://simplewealth.co.za"
  }
};
---

<BaseLayout
  title="About You — Simple Wealth"
  description="Whether you're building wealth, planning for retirement, or thinking about your legacy, it helps to have a trusted adviser by your side."
  activePage="about-you"
  showSocialInFooter={true}
  schema={schema}
>
  <section class="hero hero--short">
    <div class="hero__inner">
      <h1 class="fade-up">Built for people who take their finances seriously</h1>
      <p class="fade-up">Whether you're building wealth, planning for retirement, running a business or thinking about your legacy, it helps to have a trusted adviser by your side. Our clients come from all walks of life, but they share one thing in common &mdash; they want to make smart decisions with confidence and clarity.</p>
    </div>
  </section>

  <!-- Who We Work With -->
  <section class="section">
    <div class="container">
      <div class="section__header fade-up">
        <h2>Who we work with</h2>
        <p>We specialise in supporting professionals, business owners, and families with tailored financial advice.</p>
      </div>
      <div class="client-types">
        <div class="client-type fade-up">
          <div class="client-type__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h4>Families looking to balance growth and protection</h4>
        </div>
        <div class="client-type fade-up">
          <div class="client-type__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" x2="9.01" y1="9" y2="9"/><line x1="15" x2="15.01" y1="9" y2="9"/></svg>
          </div>
          <h4>People nearing or in retirement</h4>
        </div>
        <div class="client-type fade-up">
          <div class="client-type__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
          </div>
          <h4>Young professionals building wealth</h4>
        </div>
        <div class="client-type fade-up">
          <div class="client-type__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h4>Those planning to pass on their wealth</h4>
        </div>
        <div class="client-type fade-up">
          <div class="client-type__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
          </div>
          <h4>Business owners needing tailored advice</h4>
        </div>
      </div>
    </div>
  </section>

  <!-- Success Stories -->
  <section class="section section--grey">
    <div class="container">
      <div class="section__header fade-up">
        <h2>Real stories from real clients</h2>
        <p>Every client has a unique situation. Here's how we've helped people like you.</p>
      </div>
      <div class="cards-grid" style="grid-template-columns: 1fr;">
        <div class="story-card fade-up">
          <div class="story-card__content">
            <span class="story-card__tag">Investment Planning</span>
            <h3>Ben and Tara's Story</h3>
            <p>Co-founders of a design agency, Ben and Tara needed to structure their personal finances while growing their business. We helped them with investment planning, tax strategies, and estate protection &mdash; giving them the confidence to focus on what they do best while their wealth works in the background.</p>
          </div>
        </div>
        <div class="story-card fade-up">
          <div class="story-card__content">
            <span class="story-card__tag">Tax Planning</span>
            <h3>Michael's Story</h3>
            <p>A 42-year-old architect, Michael knew he was paying more tax than necessary but wasn't sure how to fix it. We optimised his tax efficiency through ISA and pension management, plus restructured his limited company income &mdash; saving him thousands each year.</p>
          </div>
        </div>
        <div class="story-card fade-up">
          <div class="story-card__content">
            <span class="story-card__tag">Estate Planning</span>
            <h3>Evelyn's Story</h3>
            <p>A 68-year-old widow, Evelyn wanted to ensure her family was properly looked after. We created a comprehensive estate plan including will updates, power of attorney, and lifetime gifting strategies &mdash; giving her peace of mind that her wishes would be carried out.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <TestimonialsCarousel grey={false} />

  <CtaSection />
</BaseLayout>
