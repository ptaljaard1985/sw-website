---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
import TestimonialsCarousel from '../components/TestimonialsCarousel.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "About You — Simple Wealth",
  "description": "Whether you're building wealth, planning for retirement, or thinking about your legacy, it helps to have a trusted adviser by your side.",
  "publisher": {
    "@type": "FinancialService",
    "name": "Simple Wealth",
    "url": "https://simplewealth.co.za",
    "email": "info@simplewealth.co.za",
    "telephone": "087 012 5628",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Office 7.17, Workshop17, 7th Floor, Ballito Junction Regional Mall, Leonora Dr",
      "addressLocality": "Ballito",
      "postalCode": "4399",
      "addressCountry": "ZA"
    }
  }
};
---

<BaseLayout
  title="About You — Simple Wealth"
  description="Whether you're building wealth, planning for retirement, or thinking about your legacy, it helps to have a trusted adviser by your side."
  activePage="about-you"
  showSocialInFooter={true}
  schema={schema}
>
  <section class="hero hero--short">
    <div class="hero__inner">
      <h1 class="fade-up">A clear plan for the road ahead</h1>
      <p class="fade-up">Whether you're building wealth, planning for retirement, running a business or thinking about your legacy, it helps to have a trusted adviser by your side. Our clients come from all walks of life, but they share one thing in common: they want to make smart decisions with confidence and clarity.</p>
    </div>
  </section>

  <!-- Who We Work With -->
  <section class="section">
    <div class="container">
      <div class="section__header fade-up">
        <h2>Who we work best with</h2>
        <p>You might recognise yourself in one of these.</p>
      </div>
      <div class="client-types">
        <div class="client-type fade-up">
          <div class="client-type__icon">
            <!-- Lucide: Compass -->
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
          </div>
          <h4>Professionals earning well but unsure if their money is working hard enough</h4>
        </div>
        <div class="client-type fade-up">
          <div class="client-type__icon">
            <!-- Lucide: Sunset -->
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 10V2"/><path d="m4.93 10.93 1.41 1.41"/><path d="M2 18h2"/><path d="M20 18h2"/><path d="m19.07 10.93-1.41 1.41"/><path d="M22 22H2"/><path d="m16 6-4 4-4-4"/><path d="M16 18a4 4 0 0 0-8 0"/></svg>
          </div>
          <h4>Pre-retirees wanting to know they're doing the right things in the lead up to retirement</h4>
        </div>
        <div class="client-type fade-up">
          <div class="client-type__icon">
            <!-- Lucide: Wallet -->
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg>
          </div>
          <h4>Retirees who want to draw a sustainable retirement income in a tax-efficient manner</h4>
        </div>
        <div class="client-type fade-up">
          <div class="client-type__icon">
            <!-- Lucide: Building2 -->
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>
          </div>
          <h4>Business owners whose personal and business finances are tangled</h4>
        </div>
      </div>
    </div>
  </section>

  <!-- How We Work With You -->
  <section class="section section--grey" id="process">
    <div class="container">
      <div class="section__header fade-up"><h2>How we work with you</h2><p>A proactive process designed for every stage of life.</p></div>
      <div class="steps steps--bordered">
        <div class="step fade-up"><div class="step__number">1</div><h3>Introductory call</h3><p>A brief 15&ndash;30 minute introductory call allowing both parties to confirm alignment with expertise.</p></div>
        <div class="step fade-up"><div class="step__number">2</div><h3>Family meeting</h3><p>A 90-minute meeting (in-person or virtual) to understand family goals, needs, and concerns.</p></div>
        <div class="step fade-up"><div class="step__number">3</div><h3>Review assessment</h3><p>A follow-up meeting reviewing findings and recommendations in plain language.</p></div>
      </div>
      <div class="steps steps--centered">
        <div class="step fade-up"><div class="step__number">4</div><h3>Annual service calendar</h3><p>Four quarterly touchpoints to keep your plan on track as life and markets evolve.</p></div>
      </div>
      <div style="text-align: center; margin-top: 48px;" class="fade-up">
        <a href="/contact/" class="btn btn--primary">Book a free call</a>
      </div>
    </div>
  </section>

  <TestimonialsCarousel grey={false} />

  <CtaSection />
</BaseLayout>
