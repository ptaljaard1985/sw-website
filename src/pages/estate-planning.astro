---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
import TestimonialsCarousel from '../components/TestimonialsCarousel.astro';

const schema = [{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Estate Planning",
  "description": "Estate planning that makes sure your wealth goes to the right people, at the right time, in the right way.",
  "provider": {
    "@type": "FinancialService",
    "name": "Simple Wealth",
    "url": "https://simplewealth.co.za"
  },
  "areaServed": [
    { "@type": "Country", "name": "South Africa" },
    { "@type": "AdministrativeArea", "name": "KwaZulu-Natal" },
    { "@type": "City", "name": "Ballito" },
    { "@type": "City", "name": "Umhlali" }
  ],
  "serviceType": "Estate Planning"
}, {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How do you work with my attorney?", "acceptedAnswer": { "@type": "Answer", "text": "We handle the financial planning side and coordinate with your attorney to make sure your will, trusts, and financial plan are all aligned." } },
    { "@type": "Question", "name": "How often should I update my estate plan?", "acceptedAnswer": { "@type": "Answer", "text": "We review it at least once a year as part of our annual process. That's where we pick up any changes in your life or in the law that affect your plan." } },
    { "@type": "Question", "name": "How involved will I be?", "acceptedAnswer": { "@type": "Answer", "text": "We work collaboratively with you throughout the process. We take the time to understand your needs, present you with clear options, and help you make informed decisions. Nothing happens without your input." } },
    { "@type": "Question", "name": "How do you reduce estate duty?", "acceptedAnswer": { "@type": "Answer", "text": "We use legitimate strategies including donations tax exemptions, trust structures, and beneficiary nominations to ensure as much of your wealth reaches your family as possible." } },
    { "@type": "Question", "name": "What happens if laws change?", "acceptedAnswer": { "@type": "Answer", "text": "Our annual review process means any legislative changes that affect your estate plan will be picked up and addressed." } }
  ]
}];
---

<BaseLayout
  title="Estate Planning — Simple Wealth"
  description="Estate planning that makes sure your wealth goes to the right people, at the right time, in the right way."
  activePage="estate-planning"
  showSocialInFooter={false}
  schema={schema}
>
  <section class="hero hero--short">
    <div class="hero__inner">
      <span class="service-hero-badge fade-up">Estate Planning</span>
      <h1 class="fade-up">Plan your legacy with clarity and care</h1>
      <p class="fade-up">Make sure your wealth goes to the right people, at the right time, in the right way.</p>
      <div class="btn-group fade-up">
        <a href="/contact/" class="btn btn--primary">Book a free call</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header fade-up">
        <h2>Are you confident your estate is in order?</h2>
        <p>These are the concerns we hear most often.</p>
      </div>
      <div class="cards-grid">
        <div class="card problem-card fade-up">
          <div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg></div>
          <h3>You're not sure who will inherit what and when</h3>
          <p>Without a clear plan, your wishes may not be followed and your family could face confusion or disputes.</p>
        </div>
        <div class="card problem-card fade-up">
          <div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></div>
          <h3>You're concerned about your family's future security</h3>
          <p>You want to make sure the people closest to you are protected financially and have immediate access to funds when they need it most.</p>
        </div>
        <div class="card problem-card fade-up">
          <div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg></div>
          <h3>You don't have enough liquidity to cover estate costs</h3>
          <p>Estate duty, executor fees, and capital gains tax are due before your heirs receive anything.</p>
        </div>
        <div class="card problem-card fade-up">
          <div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3.5 5.5 5 7l2.5-2.5"/><path d="M3.5 11.5 5 13l2.5-2.5"/><path d="M3.5 17.5 5 19l2.5-2.5"/><path d="M11 6h9"/><path d="M11 12h9"/><path d="M11 18h9"/></svg></div>
          <h3>Your beneficiary nominations are out of date</h3>
          <p>Outdated nominations on policies and investment accounts can create delays and confusion for your loved ones.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--grey">
    <div class="container">
      <div class="section__header fade-up">
        <h2>Our approach to estate planning</h2>
        <p>Every family's situation is different. Here's how we approach estate planning.</p>
      </div>
      <div class="cards-grid">
        <div class="card fade-up">
          <div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg></div>
          <h3>Will and trust review</h3>
          <p>We review your will and any existing trusts to make sure they reflect your current wishes and family structure.</p>
        </div>
        <div class="card fade-up">
          <div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="12" x="8" y="2" rx="2"/><path d="M4 14h16"/><path d="M4 14v4a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-4"/><path d="m9 10 2 2 4-4"/></svg></div>
          <h3>Beneficiary audit</h3>
          <p>We check that every policy and investment account has the right beneficiaries nominated and up to date.</p>
        </div>
        <div class="card fade-up">
          <div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg></div>
          <h3>Estate duty and liquidity planning</h3>
          <p>We help you structure your estate to minimise estate duty and make sure there's enough cash available so your family isn't left with an unexpected bill or forced to sell assets.</p>
        </div>
        <div class="card fade-up">
          <div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m9 16 2 2 4-4"/></svg></div>
          <h3>Regular reviews</h3>
          <p>As your life changes, we revisit your estate plan. When legal documents need updating, we're happy to coordinate with your attorney.</p>
        </div>
      </div>
    </div>
  </section>

  <TestimonialsCarousel grey={false} />

  <section class="section section--grey">
    <div class="container">
      <div class="section__header fade-up">
        <h2>Questions you may have about our estate planning service</h2>
      </div>
      <div class="faq-list fade-up">
        <div class="faq-item">
          <button class="faq-question">How do you work with my attorney?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button>
          <div class="faq-answer"><div class="faq-answer__inner"><p>We handle the financial planning side and coordinate with your attorney to make sure your will, trusts, and financial plan are all aligned.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">How often should I update my estate plan?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button>
          <div class="faq-answer"><div class="faq-answer__inner"><p>We review it at least once a year as part of our annual process. That's where we pick up any changes in your life or in the law that affect your plan.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">How involved will I be?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button>
          <div class="faq-answer"><div class="faq-answer__inner"><p>We work collaboratively with you throughout the process. We take the time to understand your needs, present you with clear options, and help you make informed decisions. Nothing happens without your input.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">How do you reduce estate duty?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button>
          <div class="faq-answer"><div class="faq-answer__inner"><p>We use legitimate strategies including donations tax exemptions, trust structures, and beneficiary nominations to ensure as much of your wealth reaches your family as possible.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">What happens if laws change?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button>
          <div class="faq-answer"><div class="faq-answer__inner"><p>Our annual review process means any legislative changes that affect your estate plan will be picked up and addressed.</p></div></div>
        </div>
      </div>
    </div>
  </section>

  <CtaSection />
</BaseLayout>
