---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Simple Wealth",
  "url": "https://simplewealth.co.za/contact/",
  "description": "Book a free call with Simple Wealth. A short phone call will give us both a chance to make sure your situation matches our expertise.",
  "mainEntity": { "@type": "FinancialService", "@id": "https://simplewealth.co.za/#organization", "name": "Simple Wealth" }
};
---

<BaseLayout
  title="Contact — Simple Wealth"
  description="Book a free call with Simple Wealth. A short phone call will give us both a chance to make sure your situation matches our expertise."
  activePage="contact"
  showSocialInFooter={true}
  schema={schema}
>
  <section class="hero hero--short">
    <div class="hero__inner">
      <h1 class="fade-up">Book a free call</h1>
      <p class="fade-up">A short phone call will give us both a chance to see if our expertise matches your needs.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div>
          <h2 class="contact-intro fade-up">Get in touch</h2>
          <p class="fade-up">Fill in the form below and we'll be in touch within one business day to arrange your free call.</p>

          <form class="contact-form fade-up" name="contact" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" action="/contact-success/">
            <p class="visually-hidden">
              <label>Don't fill this out if you're human: <input name="bot-field"></label>
            </p>
            <div class="form-group">
              <label for="name">Full name</label>
              <input type="text" id="name" name="name" placeholder="Your full name" required>
            </div>
            <div class="form-group">
              <label for="email">Email address</label>
              <input type="email" id="email" name="email" placeholder="you@example.com" required>
            </div>
            <div class="form-group">
              <label for="phone">Phone number</label>
              <input type="tel" id="phone" name="phone" placeholder="Your phone number" required>
            </div>
            <div class="form-group">
              <label for="age">Age</label>
              <input type="text" id="age" name="age" placeholder="Your age" required>
            </div>
            <div class="form-group">
              <label for="location">Location</label>
              <input type="text" id="location" name="location" placeholder="Your city or town" required>
            </div>
            <div class="form-group">
              <label for="service">What can we help with?</label>
              <select id="service" name="service" required>
                <option value="">Select a service...</option>
                <option value="investment">Investment planning</option>
                <option value="risk">Risk planning</option>
                <option value="estate">Estate planning</option>
                <option value="tax">Tax planning</option>
                <option value="general">General enquiry</option>
              </select>
            </div>
            <div class="form-group">
              <label for="assets">Investable assets</label>
              <select id="assets" name="assets" required>
                <option value="">Select a range...</option>
                <option value="under-2m">Less than R2m</option>
                <option value="2m-10m">R2m–R10m</option>
                <option value="10m-30m">R10m–R30m</option>
                <option value="30m-50m">R30m–R50m</option>
                <option value="50m+">R50m+</option>
              </select>
            </div>
            <div class="form-group">
              <label for="adviser">Are you currently working with a financial adviser?</label>
              <select id="adviser" name="adviser" required>
                <option value="">Select an option...</option>
                <option value="yes">Yes</option>
                <option value="no">No</option>
                <option value="complicated">It's complicated</option>
              </select>
            </div>
            <div class="form-group">
              <label for="referral">How did you hear about us?</label>
              <select id="referral" name="referral" required>
                <option value="">Select an option...</option>
                <option value="google">Google search</option>
                <option value="referral">Referral from a friend or colleague</option>
                <option value="linkedin">LinkedIn</option>
                <option value="article">Article or blog post</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Your message</label>
              <textarea id="message" name="message" placeholder="Tell us a bit about your situation and what you're looking for..." required></textarea>
            </div>
            <div class="form-group form-group--checkbox">
              <label for="fee-acknowledgement"><input type="checkbox" id="fee-acknowledgement" name="fee-acknowledgement" required> I understand that for investable assets less than R2m, our minimum annual fee may not be cost-effective.</label>
            </div>
            <button type="submit" class="btn btn--primary">Send your message</button>
          </form>
        </div>

        <div>
          <div class="contact-info-card fade-up">
            <h3>Contact details</h3>

            <div class="contact-info-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <div>
                <h4>Email</h4>
                <p><a href="mailto:info@simplewealth.co.za">info@simplewealth.co.za</a></p>
              </div>
            </div>

            <div class="contact-info-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <div>
                <h4>Phone</h4>
                <p><a href="tel:+27870125628">087 012 5628</a></p>
              </div>
            </div>

            <div class="contact-info-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <div>
                <h4>Office</h4>
                <p><a href="https://maps.app.goo.gl/z5PbmNjmUYrW6vDD7" target="_blank" rel="noopener">Office 7.17, Workshop17, 7th Floor, Ballito Junction Regional Mall, Leonora Dr, Ballito, KwaZulu-Natal, 4399</a></p>
              </div>
            </div>

            <div class="contact-info-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div>
                <h4>Response time</h4>
                <p>We aim to respond within one business day</p>
              </div>
            </div>
          </div>

          <div class="contact-map fade-up">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3000!2d31.2036188!3d-29.5266659!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1ef715d63d4a00df%3A0xfafd4b1168f6fd97!2sSimple%20Wealth!5e0!3m2!1sen!2sza!4v1" width="100%" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" sandbox="allow-scripts allow-same-origin"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
  <script is:inline slot="scripts">
    const messages = {
      name: 'Please enter your full name.',
      email: 'Please enter a valid email address.',
      phone: 'Please enter your phone number.',
      age: 'Please enter your age.',
      location: 'Please enter your city or town.',
      service: 'Please select a service.',
      assets: 'Please select an investable assets range.',
      adviser: 'Please let us know if you have a financial adviser.',
      referral: 'Please let us know how you heard about us.',
      message: 'Please enter a message.'
    };

    document.querySelectorAll('.contact-form [required]').forEach(function(field) {
      var msg = messages[field.name] || '';
      field.addEventListener('invalid', function() {
        field.setCustomValidity(msg);
      });
      field.addEventListener('input', function() {
        field.setCustomValidity('');
      });
      field.addEventListener('change', function() {
        field.setCustomValidity('');
      });
    });
  </script>
</BaseLayout>
