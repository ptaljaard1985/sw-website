---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
import TestimonialsCarousel from '../components/TestimonialsCarousel.astro';
import LeadMagnet from '../components/LeadMagnet.astro';

const schema = [{
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About Simple Wealth",
  "url": "https://simplewealth.co.za/about-us/",
  "description": "Choosing someone to help with your finances is a big decision. Learn about our team, values, and why clients trust Simple Wealth.",
  "mainEntity": { "@type": "FinancialService", "@id": "https://simplewealth.co.za/#organization", "name": "Simple Wealth" }
}, {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Pierre Taljaard",
  "jobTitle": "Director & Financial Planner",
  "image": "https://simplewealth.co.za/images/headshot-pierre.webp",
  "worksFor": { "@type": "FinancialService", "@id": "https://simplewealth.co.za/#organization", "name": "Simple Wealth" },
  "hasCredential": [
    { "@type": "EducationalOccupationalCredential", "name": "Certified Financial Planner (CFP)" },
    { "@type": "EducationalOccupationalCredential", "name": "CFA Charterholder" }
  ],
  "sameAs": ["https://www.linkedin.com/in/ptaljaard/", "https://www.pierretaljaard.com/"]
}];
---

<BaseLayout
  title="About Us — Simple Wealth"
  description="Choosing someone to help with your finances is a big decision. Learn about our team, values, and why clients trust Simple Wealth."
  activePage="about-us"
  showSocialInFooter={true}
  schema={schema}
>
  <!-- Hero -->
  <section class="hero hero--short">
    <div class="hero__inner">
      <h1 class="fade-up">Trust starts with getting to know us</h1>
      <p class="fade-up">Choosing someone to help with your finances is a big decision. You should feel confident not just in our advice, but in who we are. Here's a bit about us.</p>
    </div>
  </section>

  <!-- Founder Quote -->
  <section class="section">
    <div class="container">
      <div class="founder-quote fade-up">
        <blockquote>&ldquo;I saw that financial advice was becoming too complex for clients, so I decided to do something different. That's how Simple Wealth was born.&rdquo;</blockquote>
        <cite>&mdash; Pierre Taljaard, Director &amp; Financial Planner</cite>
      </div>
    </div>
  </section>

  <!-- Origin -->
  <section class="section section--grey">
    <div class="container">
      <div class="section__header fade-up">
        <h2>Our story</h2>
        <p>We started Simple Wealth to challenge the way financial advice is often delivered. Too often it's complicated, unclear, and focused more on products than people.</p>
        <p>We believe good financial planning should give you <strong>clarity</strong>, <strong>confidence</strong>, and the <strong>freedom</strong> to focus on what really matters. That's why we simplify the complex and put your life at the centre of every decision.</p>
      </div>
    </div>
  </section>

  <!-- Meet Pierre -->
  <section class="section">
    <div class="container">
      <div class="bio-section fade-up">
        <div class="bio-section__photo"><img src="/images/headshot-pierre.webp" alt="Pierre Taljaard, Certified Financial Planner" width="400" height="400" loading="lazy"></div>
        <div class="bio-section__content">
          <h2>Pierre Taljaard</h2>
          <p class="bio-section__title">Director &amp; Financial Planner</p>
          <p>Pierre's natural love for business and numbers made financial services a clear career path. Initially aspiring to become an equity analyst, he discovered his true passion when he saw how great financial planning can change a family's future.</p>
          <p>Frustrated by an industry that often creates unnecessary complexity to confuse clients, Pierre is deeply driven to simplify finance for those who believe life is about much more than money. Based on the KZN north coast, he is passionate about building long-term relationships with families, acting as an independent guide who prioritises their unique goals and values above all else.</p>
          <div class="bio-section__credentials">
            <span>CFA Charterholder</span>
            <span>CFP Professional</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="section section--grey">
    <div class="container">
      <div class="section__header fade-up">
        <h2>Our promise to you</h2>
        <p>Four principles that guide everything we do.</p>
      </div>
      <div class="values-grid">
        <div class="value-card fade-up">
          <h3>Integrity</h3>
          <p>We always act in your best interests. Honest, transparent advice that puts you first.</p>
        </div>
        <div class="value-card fade-up">
          <h3>Clarity</h3>
          <p>We cut through the jargon and give you advice you can actually understand.</p>
        </div>
        <div class="value-card fade-up">
          <h3>Partnership</h3>
          <p>We work with you, not just for you. This is a long-term relationship, not a one-time service.</p>
        </div>
        <div class="value-card fade-up">
          <h3>Accountability</h3>
          <p>We follow through, review regularly, and adjust when life changes.</p>
        </div>
      </div>
    </div>
  </section>

  <TestimonialsCarousel grey={false} />

  <!-- How We Work With You -->
  <section class="section section--grey" id="process">
    <div class="container">
      <div class="section__header fade-up"><h2>How we work with you</h2><p>A proactive process designed for every stage of life.</p></div>
      <div class="steps steps--bordered">
        <div class="step fade-up"><div class="step__number">1</div><h3>Introductory call</h3><p>A 10-minute call to see if our expertise matches your needs.</p></div>
        <div class="step fade-up"><div class="step__number">2</div><h3>Family meeting</h3><p>A 90-minute meeting (in-person or virtual) to understand your family goals, needs, and concerns.</p></div>
        <div class="step fade-up"><div class="step__number">3</div><h3>Review assessment</h3><p>A follow-up meeting to discuss our findings and recommendations.</p></div>
      </div>
      <div class="steps steps--centered">
        <div class="step fade-up"><div class="step__number">4</div><h3>Annual service calendar</h3><p>Four annual touchpoints to keep your plan on track as life and markets evolve.<br><a href="/files/2026-simple-wealth-client-service-calendar.pdf" target="_blank" rel="noopener" class="card__link">View our service calendar <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a></p></div>
      </div>
    </div>
  </section>

  <LeadMagnet grey={false} />

  <CtaSection />
</BaseLayout>
