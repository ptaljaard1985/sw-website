---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
import TestimonialsCarousel from '../components/TestimonialsCarousel.astro';

const schema = [{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Investment Planning",
  "url": "https://www.simplewealth.co.za/investment-planning/",
  "description": "We help you implement a smart investment strategy that aligns with your goals and time horizon.",
  "provider": { "@type": "FinancialService", "@id": "https://www.simplewealth.co.za/#organization", "name": "Simple Wealth" },
  "areaServed": [
    { "@type": "Country", "name": "South Africa" },
    { "@type": "AdministrativeArea", "name": "KwaZulu-Natal" },
    { "@type": "City", "name": "Ballito" },
    { "@type": "City", "name": "Umhlali" }
  ],
  "serviceType": "Investment Planning"
}, {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.simplewealth.co.za/" },
    { "@type": "ListItem", "position": 2, "name": "Investment Planning", "item": "https://www.simplewealth.co.za/investment-planning/" }
  ]
}, {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How do you decide where to invest my money?", "acceptedAnswer": { "@type": "Answer", "text": "We start by understanding your goals, risk tolerance, and time horizon. From there, we build a diversified portfolio designed to grow steadily over time, and help you understand what the journey is likely to look and feel like." } },
    { "@type": "Question", "name": "How often will you review my investments?", "acceptedAnswer": { "@type": "Answer", "text": "We review your portfolio at least once a year. A well-built portfolio doesn't need constant tinkering, it needs patience and discipline. We'll only suggest changes when your life circumstances materially change." } },
    { "@type": "Question", "name": "How much money do I need to get started?", "acceptedAnswer": { "@type": "Answer", "text": "We don't have account minimums, but our minimum annual fee means that clients with investable assets below R2 million may not find our service cost-effective. We'll have an honest conversation during the introductory call about whether we're the right fit." } },
    { "@type": "Question", "name": "Will I know what I'm invested in?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. You'll always know where your money is and what it's been invested in." } },
    { "@type": "Question", "name": "Can you help consolidate my old investments and retirement funds?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, this is one of the most common things we help with. We'll review all your existing accounts, assess whether consolidation makes sense, and handle the process for you to simplify your financial life." } },
    { "@type": "Question", "name": "Can you help me plan a sustainable retirement income?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. This is core to what we do. We model how long your money will last under different drawdown rates and market scenarios, structure your income across living annuities, discretionary investments, and offshore assets to minimise tax, and stress-test your plan against sequence-of-returns risk. The goal is a retirement income you can't outlive." } }
  ]
}];
---

<BaseLayout
  title="Investment Planning | Financial Adviser in Ballito | Simple Wealth"
  description="A smart investment strategy aligned with your goals and time horizon. Independent advice from a Certified Financial Planner in Ballito, KZN. Book a free call."
  activePage="investment-planning"
  showSocialInFooter={false}
  schema={schema}
>
  <!-- Hero -->
  <section class="hero hero--short">
    <div class="hero__inner">
      <span class="service-hero-badge fade-up">Investment Planning</span>
      <h1 class="fade-up">Make your investments work for you</h1>
      <p class="fade-up">We help you implement a smart investment strategy that aligns with your goals and time horizon, so you can grow and preserve your wealth with confidence.</p>
      <div class="btn-group fade-up">
        <a href="/contact/" class="btn btn--primary">Book a free call</a>
      </div>
    </div>
  </section>

  <!-- Common Issues -->
  <section class="section">
    <div class="container">
      <div class="section__header fade-up">
        <h2>Are you facing these common investment frustrations?</h2>
        <p>Investing should be straightforward, but it rarely feels that way. These are the concerns we hear most often.</p>
      </div>
      <div class="cards-grid">
        <div class="card problem-card fade-up">
          <div class="card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m16.24 7.76-1.804 5.411a2 2 0 0 1-1.265 1.265L7.76 16.24l1.804-5.411a2 2 0 0 1 1.265-1.265z"/></svg>
          </div>
          <h3>You don't know if your portfolio is right for you</h3>
          <p>Your circumstances have changed, but your investments haven't kept up.</p>
        </div>
        <div class="card problem-card fade-up">
          <div class="card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15.5 2H8.6c-.4 0-.8.2-1.1.5-.3.3-.5.7-.5 1.1v12.8c0 .4.2.8.5 1.1.3.3.7.5 1.1.5h9.8c.4 0 .8-.2 1.1-.5.3-.3.5-.7.5-1.1V6.5z"/><path d="M3 7.6v12.8c0 .4.2.8.5 1.1.3.3.7.5 1.1.5h9.8"/><path d="M15 2v5h5"/></svg>
          </div>
          <h3>Your investments are scattered across too many places</h3>
          <p>Old retirement funds, unit trusts, offshore accounts. Nobody is looking at the full picture.</p>
        </div>
        <div class="card problem-card fade-up">
          <div class="card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22z"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
          </div>
          <h3>You're confused by jargon and complex options</h3>
          <p>The investment world is full of technical language that makes it hard to feel confident about your choices.</p>
        </div>
        <div class="card problem-card fade-up">
          <div class="card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 22h14"/><path d="M5 2h14"/><path d="M17 22v-4.172a2 2 0 0 0-.586-1.414L12 12l-4.414 4.414A2 2 0 0 0 7 17.828V22"/><path d="M7 2v4.172a2 2 0 0 0 .586 1.414L12 12l4.414-4.414A2 2 0 0 0 17 6.172V2"/></svg>
          </div>
          <h3>You're not sure when you'll be able to retire</h3>
          <p>Without a clear target, it's hard to know if you're saving enough or if you can afford to stop.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Approach -->
  <section class="section section--grey">
    <div class="container">
      <div class="section__header fade-up">
        <h2>Our approach to investment planning</h2>
        <p>Every client's situation is different. Here's how we make sure your investment strategy works for you.</p>
      </div>
      <div class="cards-grid">
        <div class="card fade-up">
          <div class="card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3>Diversified by design</h3>
          <p>We build portfolios diversified across local and offshore assets, industries, and regions to manage risk, capture long-term growth, and provide currency diversification.</p>
        </div>
        <div class="card fade-up">
          <div class="card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>
          </div>
          <h3>Asset classes that work</h3>
          <p>We focus on asset classes with a proven track record of delivering real, inflation-beating returns over the long term.</p>
        </div>
        <div class="card fade-up">
          <div class="card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" x2="5" y1="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
          </div>
          <h3>Lower fees, better outcomes</h3>
          <p>We review your existing investments for hidden and unnecessary costs, and structure your portfolio to keep fees as low as possible.</p>
        </div>
        <div class="card fade-up">
          <div class="card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m9 16 2 2 4-4"/></svg>
          </div>
          <h3>Annual review</h3>
          <p>We meet with you at least once a year to review your portfolio, model your retirement income sustainability, and adjust your strategy as your life changes.</p>
        </div>
      </div>
    </div>
  </section>

  <TestimonialsCarousel grey={false} />

  <!-- FAQ -->
  <section class="section section--grey">
    <div class="container">
      <div class="section__header fade-up">
        <h2>Questions you may have about our investment planning service</h2>
      </div>
      <div class="faq-list fade-up">
        <div class="faq-item">
          <button class="faq-question">How do you decide where to invest my money?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button>
          <div class="faq-answer"><div class="faq-answer__inner"><p>We start by understanding your goals, risk tolerance, and time horizon. From there, we build a diversified portfolio designed to grow steadily over time, and help you understand what the journey is likely to look and feel like.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">How often will you review my investments?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button>
          <div class="faq-answer"><div class="faq-answer__inner"><p>We review your portfolio at least once a year. A well-built portfolio doesn't need constant tinkering, it needs patience and discipline. We'll only suggest changes when your life circumstances materially change.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">How much money do I need to get started?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button>
          <div class="faq-answer"><div class="faq-answer__inner"><p>We don't have account minimums, but our minimum annual fee means that clients with investable assets below R2 million may not find our service cost-effective. We'll have an honest conversation during the introductory call about whether we're the right fit.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">Will I know what I'm invested in?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button>
          <div class="faq-answer"><div class="faq-answer__inner"><p>Yes. You'll always know where your money is and what it's been invested in.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">Can you help consolidate my old investments and retirement funds?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button>
          <div class="faq-answer"><div class="faq-answer__inner"><p>Yes, this is one of the most common things we help with. We'll review all your existing accounts, assess whether consolidation makes sense, and handle the process for you to simplify your financial life.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">Can you help me plan a sustainable retirement income?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button>
          <div class="faq-answer"><div class="faq-answer__inner"><p>Yes. This is core to what we do. We model how long your money will last under different drawdown rates and market scenarios, structure your income across living annuities, discretionary investments, and offshore assets to minimise tax, and stress-test your plan against sequence-of-returns risk. The goal is a retirement income you can't outlive.</p></div></div>
        </div>
      </div>
    </div>
  </section>

  <CtaSection />
</BaseLayout>
