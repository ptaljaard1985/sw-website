---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
import TestimonialsCarousel from '../components/TestimonialsCarousel.astro';
import LeadMagnet from '../components/LeadMagnet.astro';

const schema = [{
  "@context": "https://schema.org",
  "@type": "FinancialService",
  "@id": "https://simplewealth.co.za/#organization",
  "name": "Simple Wealth",
  "alternateName": "Simple Wealth (Pty) Ltd",
  "description": "Independent financial planning from Ballito on the KZN north coast. We help affluent families align their wealth with their values, lifestyle, and long-term goals.",
  "url": "https://simplewealth.co.za",
  "image": "https://simplewealth.co.za/images/hero-adviser.webp",
  "logo": "https://simplewealth.co.za/logo.png",
  "telephone": "087 012 5628",
  "email": "info@simplewealth.co.za",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Office 7.17, Workshop17, 7th Floor, Ballito Junction Regional Mall, Leonora Dr",
    "addressLocality": "Ballito",
    "addressRegion": "KwaZulu-Natal",
    "postalCode": "4399",
    "addressCountry": "ZA"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": -29.5266659, "longitude": 31.2036188 },
  "hasMap": "https://maps.app.goo.gl/z5PbmNjmUYrW6vDD7",
  "areaServed": [
    { "@type": "Country", "name": "South Africa" },
    { "@type": "AdministrativeArea", "name": "KwaZulu-Natal" },
    { "@type": "City", "name": "Ballito" },
    { "@type": "City", "name": "Umhlali" }
  ],
  "serviceType": ["Investment Planning", "Risk Planning", "Estate Planning", "Tax Planning"],
  "priceRange": "$$",
  "founder": {
    "@type": "Person",
    "name": "Pierre Taljaard",
    "jobTitle": "Director & Financial Planner",
    "hasCredential": [
      { "@type": "EducationalOccupationalCredential", "credentialCategory": "Professional Certification", "name": "Certified Financial Planner (CFP)" },
      { "@type": "EducationalOccupationalCredential", "credentialCategory": "Professional Certification", "name": "CFA Charterholder" }
    ]
  },
  "hasCredential": {
    "@type": "EducationalOccupationalCredential",
    "credentialCategory": "Regulatory License",
    "name": "Financial Services Provider Licence",
    "recognizedBy": { "@type": "GovernmentOrganization", "name": "Financial Sector Conduct Authority (FSCA)" },
    "identifier": "FSP 50637"
  },
  "knowsAbout": ["financial planning", "investment planning", "tax planning", "estate planning", "risk planning", "wealth management", "retirement planning", "KZN north coast financial adviser", "Ballito financial planner", "KwaZulu-Natal independent financial adviser"],
  "foundingDate": "2020-04-01",
  "sameAs": ["https://www.linkedin.com/in/ptaljaard/", "https://www.pierretaljaard.com/", "https://g.page/simple-wealth-fp"]
}, {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Simple Wealth",
  "url": "https://simplewealth.co.za"
}, {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Do you only work with high-net-worth individuals?", "acceptedAnswer": { "@type": "Answer", "text": "While we serve many clients with significant assets, we provide a professional and proactive financial planning service to any family willing to engage and pay for professional advice. We don't have account minimums, but our minimum annual fee means that clients with investable assets below R2 million may not find our service cost-effective." } },
    { "@type": "Question", "name": "What does this cost and what exactly am I paying for?", "acceptedAnswer": { "@type": "Answer", "text": "We charge a percentage-based fee on your investable assets. This covers our comprehensive proactive service across investments, tax, estate planning, and risk planning. We are not remunerated by any product providers, so our incentives are fully aligned with yours. Clients are free to disengage at any time if the perceived value is less than our fee." } },
    { "@type": "Question", "name": "How do I know you're acting in my best interest?", "acceptedAnswer": { "@type": "Answer", "text": "As a client-centred firm with no outside influence from product providers, our only incentive is to provide professional advice that results in happy clients." } },
    { "@type": "Question", "name": "What kind of results should I realistically expect?", "acceptedAnswer": { "@type": "Answer", "text": "If you actively engage with our services, you should expect long-term peace of mind and progress towards your goals. The portfolios we build are typically focused on long-term growth, which inevitably means short-term volatility and temporary declines from time to time. Our service is designed for families who understand that long-term planning requires discipline and patience." } },
    { "@type": "Question", "name": "How often will we review things, and how quickly can I reach you?", "acceptedAnswer": { "@type": "Answer", "text": "Our service calendar provides quarterly touchpoints, but we remain available for questions at any time in between. You can expect responses within one business day, and we proactively reach out when market conditions or life changes warrant a conversation. We have purposefully built a service model and client base that allow us to be available to our clients." } }
  ]
}];
---

<BaseLayout
  title="Independent Financial Planning, Ballito | Simple Wealth"
  description="Independent financial planning from Ballito, KZN north coast. We align your wealth with your values, lifestyle, and long-term goals."
  schema={schema}
>
  <link rel="preload" href="/images/hero-adviser-mobile.webp" as="image" type="image/webp" media="(max-width: 768px)" slot="head">
  <link rel="preload" href="/images/hero-adviser.webp" as="image" type="image/webp" media="(min-width: 769px)" slot="head">

  <!-- Hero -->
  <section class="hero hero--bg-photo">
    <div class="hero__bg">
      <picture>
        <source srcset="/images/hero-adviser-mobile.webp" media="(max-width: 768px)" type="image/webp">
        <img src="/images/hero-adviser.webp" alt="Multigenerational family sharing a meal together outdoors" width="1920" height="1280" loading="eager">
      </picture>
    </div>
    <div class="hero__inner">
      <div class="trust-badges fade-up">
        <div class="trust-badge"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg> Clarity</div>
        <div class="trust-badge"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg> Peace of mind</div>
        <div class="trust-badge"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg> Independent advice</div>
      </div>
      <h1 class="fade-up">Financial <span class="hero-highlight">clarity</span> for the life you've built</h1>
      <p class="fade-up">Expert financial planning that carefully aligns your money with your values, lifestyle, and long-term goals.</p>
      <div class="btn-group fade-up">
        <a href="/contact/" class="btn btn--primary">Book a free call</a>
        <a href="#services" class="btn btn--outline-white">How we help</a>
      </div>
      <div class="social-proof fade-up">
        <div class="avatar-stack">
          <span class="avatar-initial"><svg width="16" height="16" viewBox="0 0 24 24"><path fill="var(--color-gold)" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></span>
          <span class="avatar-initial"><svg width="16" height="16" viewBox="0 0 24 24"><path fill="var(--color-gold)" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></span>
          <span class="avatar-initial"><svg width="16" height="16" viewBox="0 0 24 24"><path fill="var(--color-gold)" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></span>
          <span class="avatar-initial"><svg width="16" height="16" viewBox="0 0 24 24"><path fill="var(--color-gold)" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></span>
          <span class="avatar-initial"><svg width="16" height="16" viewBox="0 0 24 24"><path fill="var(--color-gold)" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></span>
        </div>
        <div class="social-proof__text"><a href="#testimonials" class="social-proof__link"><strong>5.0 star rated</strong></a> &mdash; Trusted by families across South Africa</div>
      </div>
    </div>
  </section>

  <!-- Problem Section -->
  <section class="section" id="problems">
    <div class="container">
      <div class="section__header fade-up">
        <h2>Managing your financial life can feel complex, time consuming, and risky</h2>
        <p>Do any of these problems sound familiar?</p>
      </div>
      <div class="cards-grid">
        <div class="card problem-card fade-up"><div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div><h3>You're busy</h3><p>Planning your future takes time and focus that life doesn't always allow.</p></div>
        <div class="card problem-card fade-up"><div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg></div><h3>You don't know what you don't know</h3><p>Making important decisions about your future feels daunting without the right guidance.</p></div>
        <div class="card problem-card fade-up"><div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg></div><h3>You're overwhelmed</h3><p>Tax, retirement, investments, and estate planning all have many interconnected parts.</p></div>
        <div class="card problem-card fade-up"><div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.1 2.18a9.93 9.93 0 0 1 3.8 0"/><path d="M17.6 3.71a9.95 9.95 0 0 1 2.69 2.7"/><path d="M21.82 10.1a9.93 9.93 0 0 1 0 3.8"/><path d="M20.29 17.6a9.95 9.95 0 0 1-2.7 2.69"/><path d="M13.9 21.82a9.94 9.94 0 0 1-3.8 0"/><path d="M6.4 20.29a9.95 9.95 0 0 1-2.69-2.7"/><path d="M2.18 13.9a9.93 9.93 0 0 1 0-3.8"/><path d="M3.71 6.4a9.95 9.95 0 0 1 2.7-2.69"/></svg></div><h3>Uncertainty is holding you back</h3><p>Without a clear plan, it's easy to put off the decisions that matter most.</p></div>
      </div>
    </div>
  </section>

  <!-- Solution Section -->
  <section class="section section--grey" id="solution">
    <div class="container">
      <div class="section__header fade-up">
        <h2>We help busy families take control of their financial future.</h2>
        <p>Our clients experience the following benefits from working with us.</p>
      </div>
      <div class="cards-grid">
        <div class="card solution-card fade-up"><div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v2"/><path d="M14 2v2"/><path d="M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a2 2 0 1 1 0 4h-2"/><path d="M6 2v2"/></svg></div><h3>More time to enjoy your life</h3><p>We remove the burden of wealth management so you can focus on living.</p></div>
        <div class="card solution-card fade-up"><div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div><h3>A trusted partner by your side</h3><p>Regular check-ins and ongoing support through every decision and milestone.</p></div>
        <div class="card solution-card fade-up"><div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg></div><h3>Confidence in every decision</h3><p>No confusion. Just clear advice you can act on.</p></div>
        <div class="card solution-card fade-up"><div class="card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.106 5.553a2 2 0 0 0 1.788 0l3.659-1.83A1 1 0 0 1 21 4.619v12.764a1 1 0 0 1-.553.894l-4.553 2.277a2 2 0 0 1-1.788 0l-4.212-2.106a2 2 0 0 0-1.788 0l-3.659 1.83A1 1 0 0 1 3 19.381V6.618a1 1 0 0 1 .553-.894l4.553-2.277a2 2 0 0 1 1.788 0z"/><path d="M15 5.764v15"/><path d="M9 3.236v15"/></svg></div><h3>A clear plan for what's ahead</h3><p>A step-by-step roadmap so you always know the next step.</p></div>
      </div>
      <div class="section-cta-center fade-up">
        <a href="/contact/" class="btn btn--primary">Book a free call</a>
      </div>
    </div>
  </section>

  <TestimonialsCarousel grey={false} />

  <!-- Services Section -->
  <section class="section section--grey" id="services">
    <div class="container">
      <div class="section__header fade-up">
        <h2>How we help you</h2>
        <p>We provide expert guidance across four key areas of financial planning.</p>
      </div>
      <div class="cards-grid">
        <div class="card card--with-photo fade-up"><div class="card__photo"><img loading="lazy" src="/images/service-investment.webp" alt="Magnifying glass analysing financial growth charts" width="1200" height="800"></div><div class="card__body"><h3>Investment planning</h3><h4>A plan for diversified long-term growth</h4><p>A disciplined strategy to turn your income into lasting wealth.</p><a href="/investment-planning/" class="card__link">Learn more <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a></div></div>
        <div class="card card--with-photo fade-up"><div class="card__photo"><img loading="lazy" src="/images/service-tax.webp" alt="Reviewing financial documents with a calculator" width="1200" height="800"></div><div class="card__body"><h3>Tax planning</h3><h4>A plan for keeping more of what you earn</h4><p>Smart tax planning means more money stays with you.</p><a href="/tax-planning/" class="card__link">Learn more <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a></div></div>
        <div class="card card--with-photo fade-up"><div class="card__photo"><img loading="lazy" src="/images/service-risk.webp" alt="Family protection" width="1200" height="802"></div><div class="card__body"><h3>Risk planning</h3><h4>A plan for when life doesn't go to plan</h4><p>The right cover so your family's lifestyle is protected, no matter what.</p><a href="/risk-planning/" class="card__link">Learn more <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a></div></div>
        <div class="card card--with-photo fade-up"><div class="card__photo"><img loading="lazy" src="/images/service-estate.webp" alt="Signing a Last Will and Testament document" width="1200" height="800"></div><div class="card__body"><h3>Estate planning</h3><h4>A plan for the people who matter most</h4><p>A clear plan so your loved ones are provided for.</p><a href="/estate-planning/" class="card__link">Learn more <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a></div></div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section" id="why">
    <div class="container">
      <div class="section__header fade-up"><h2>Why people choose Simple Wealth</h2><p>Clients choose us because we put their goals first, speak in plain English, and provide advice they can trust.</p></div>
      <div class="reasons-list">
        <div class="reason fade-up"><div class="reason__number">1</div><div><h3>Independent, advice-first approach</h3><p>We don't sell products. We give advice that's right for you.</p></div></div>
        <div class="reason fade-up"><div class="reason__number">2</div><div><h3>Personalised planning, not one-size-fits-all</h3><p>A plan designed around your goals and circumstances.</p></div></div>
        <div class="reason fade-up"><div class="reason__number">3</div><div><h3>Clear communication, no jargon</h3><p>We explain everything in plain language so you always know where you stand.</p></div></div>
        <div class="reason fade-up"><div class="reason__number">4</div><div><h3>Ongoing proactive support, not set-and-forget</h3><p>We stay involved and adjust your plan as life and markets change.</p></div></div>
      </div>
    </div>
  </section>

  <!-- How We Work With You -->
  <section class="section section--grey" id="process">
    <div class="container">
      <div class="section__header fade-up"><h2>How we work with you</h2><p>A proactive process designed for every stage of life.</p></div>
      <div class="steps steps--bordered">
        <div class="step fade-up"><div class="step__number">1</div><h3>Introductory call</h3><p>A 10-minute call to see if our expertise matches your needs.</p></div>
        <div class="step fade-up"><div class="step__number">2</div><h3>Family meeting</h3><p>A 90-minute meeting (in-person or virtual) to understand your family goals, needs, and concerns.</p></div>
        <div class="step fade-up"><div class="step__number">3</div><h3>Review assessment</h3><p>A follow-up meeting to discuss our findings and recommendations.</p></div>
      </div>
      <div class="steps steps--centered">
        <div class="step fade-up"><div class="step__number">4</div><h3>Annual service calendar</h3><p>Four annual touchpoints to keep your plan on track as life and markets evolve.<br><a href="/files/2026-simple-wealth-client-service-calendar.pdf" target="_blank" rel="noopener" class="card__link">View our service calendar <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a></p></div>
      </div>
      <div class="section-cta-center fade-up">
        <a href="/contact/" class="btn btn--primary">Book a free call</a>
      </div>
    </div>
  </section>

  <!-- What You Get -->
  <section class="section">
    <div class="container">
      <div class="section__header fade-up"><h2>Get crystal-clear financial understanding</h2><p>Here's what you can expect from working with us.</p></div>
      <div class="docs-grid">
        <div class="doc-card fade-up"><div class="doc-card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg></div><h3>Your financial life on one page</h3><p>Always know what you have and why you have it.</p></div>
        <div class="doc-card fade-up"><div class="doc-card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg></div><h3>A financial progress report</h3><p>Always know where you are and where you're going.</p></div>
        <div class="doc-card fade-up"><div class="doc-card__icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m9 12 2 2 4-4"/></svg></div><h3>A one-page action plan</h3><p>Always know what to do next.</p></div>
      </div>
    </div>
  </section>

  <LeadMagnet />

  <!-- FAQ -->
  <section class="section" id="faq">
    <div class="container">
      <div class="section__header fade-up"><h2>A few questions our clients normally ask us</h2></div>
      <div class="faq-list fade-up">
        <div class="faq-item"><button class="faq-question">Do you only work with high-net-worth individuals?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button><div class="faq-answer"><div class="faq-answer__inner"><p>While we serve many clients with significant assets, we provide a professional and proactive financial planning service to any family willing to engage and pay for professional advice. We don't have account minimums, but our minimum annual fee means that clients with investable assets below R2 million may not find our service cost-effective.</p></div></div></div>
        <div class="faq-item"><button class="faq-question">What does this cost and what exactly am I paying for?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button><div class="faq-answer"><div class="faq-answer__inner"><p>We charge a percentage-based fee on your investable assets. This covers our comprehensive proactive service across investments, tax, estate planning, and risk planning. We are not remunerated by any product providers, so our incentives are fully aligned with yours. Clients are free to disengage at any time if the perceived value is less than our fee.</p></div></div></div>
        <div class="faq-item"><button class="faq-question">How do I know you're acting in my best interest?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button><div class="faq-answer"><div class="faq-answer__inner"><p>As a client-centred firm with no outside influence from product providers, our only incentive is to provide professional advice that results in happy clients.</p></div></div></div>
        <div class="faq-item"><button class="faq-question">What kind of results should I realistically expect?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button><div class="faq-answer"><div class="faq-answer__inner"><p>If you actively engage with our services, you should expect long-term peace of mind and progress towards your goals. The portfolios we build are typically focused on long-term growth, which inevitably means short-term volatility and temporary declines from time to time. Our service is designed for families who understand that long-term planning requires discipline and patience.</p></div></div></div>
        <div class="faq-item"><button class="faq-question">How often will we review things, and how quickly can I reach you?<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button><div class="faq-answer"><div class="faq-answer__inner"><p>Our <a href="/files/2026-simple-wealth-client-service-calendar.pdf" target="_blank" rel="noopener">service calendar</a> provides quarterly touchpoints, but we remain available for questions at any time in between. You can expect responses within one business day, and we proactively reach out when market conditions or life changes warrant a conversation. We have purposefully built a service model and client base that allow us to be available to our clients.</p></div></div></div>
      </div>
    </div>
  </section>

