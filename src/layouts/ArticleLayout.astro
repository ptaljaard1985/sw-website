---
import BaseLayout from './BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  category: string;
  image: string;
  imageAlt: string;
  date: string;
  author: string;
  authorTitle: string;
  authorPhoto: string;
  authorBio: string;
  slug: string;
}

const { title, description, category, image, imageAlt, date, author, authorTitle, authorPhoto, authorBio, slug } = Astro.props;

// Get 3 random related articles, excluding current
const allArticles = await getCollection('articles');
const others = allArticles.filter(a => a.id !== slug);
for (let i = others.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [others[i], others[j]] = [others[j], others[i]];
}
const related = others.slice(0, 3);

// Parse "Month Year" date string to ISO format for schema
const months: Record<string, string> = {
  January: '01', February: '02', March: '03', April: '04',
  May: '05', June: '06', July: '07', August: '08',
  September: '09', October: '10', November: '11', December: '12'
};
const dateParts = date.split(' ');
const isoDate = dateParts.length === 2 && months[dateParts[0]]
  ? `${dateParts[1]}-${months[dateParts[0]]}-01`
  : undefined;

const schema = [{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": `https://www.simplewealth.co.za${image}`,
  ...(isoDate && { "datePublished": isoDate, "dateModified": isoDate }),
  "author": {
    "@type": "Person",
    "name": author,
    "jobTitle": authorTitle
  },
  "publisher": {
    "@type": "Organization",
    "@id": "https://www.simplewealth.co.za/#organization",
    "name": "Simple Wealth",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.simplewealth.co.za/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://www.simplewealth.co.za/articles/${slug}/`
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": [".article-hero__headline", ".article-body"]
  }
}, {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.simplewealth.co.za/" },
    { "@type": "ListItem", "position": 2, "name": "Knowledge & Insight", "item": "https://www.simplewealth.co.za/knowledge-and-insight/" },
    { "@type": "ListItem", "position": 3, "name": title, "item": `https://www.simplewealth.co.za/articles/${slug}/` }
  ]
}];

---

<BaseLayout title={`${title} — Simple Wealth`} description={description} activePage="knowledge" schema={schema} ogImage={image} ogType="article">
  <Fragment slot="head">
    {isoDate && <meta property="article:published_time" content={isoDate} />}
    <meta property="article:author" content={author} />
  </Fragment>

  <div class="reading-progress" id="readingProgress" slot="before-nav"></div>

  <!-- Article Hero -->
  <section class="article-hero">
    <div class="article-hero__bg">
      <img src={image} alt={imageAlt} width="800" height="533">
    </div>
    <div class="article-hero__content">
      <div class="article-hero__text">
        <span class="article-hero__category">{category}</span>
        <h1 class="article-hero__headline">{title}</h1>
        <div class="article-hero__meta">
          By {author} &middot; {date}<span class="read-time" id="readTime"></span>
        </div>
      </div>
    </div>
  </section>

  <!-- Article Body -->
  <article class="article-body" id="articleBody">
    <slot />
  </article>

  <!-- Author Bio -->
  <div class="author-bio">
    <div class="author-bio__divider"></div>
    <div class="author-bio__card">
      <img loading="lazy" src={authorPhoto} alt={author} class="author-bio__photo" width="400" height="400">
      <div>
        <p class="author-bio__name">{author}</p>
        <p class="author-bio__title">{authorTitle}, Simple Wealth</p>
        <p class="author-bio__text">{authorBio}</p>
        <a href="https://www.linkedin.com/in/ptaljaard/" target="_blank" rel="noopener" class="author-bio__linkedin"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg> Connect with Pierre on LinkedIn</a>
      </div>
    </div>
  </div>

  <!-- Related Articles -->
  {related.length > 0 && (
    <section class="related-articles">
      <div class="section__header">
        <h2>More from Knowledge & Insight</h2>
      </div>
      <div class="related-grid">
        {related.map(article => (
          <a href={`/articles/${article.id}/`} class="related-card">
            <div class="related-card__photo">
              <img loading="lazy" src={article.data.image} alt={article.data.imageAlt} width="800" height="533">
            </div>
            <div class="related-card__body">
              <span class="related-card__category">{article.data.category}</span>
              <h3 class="related-card__headline">{article.data.title}</h3>
              <p class="related-card__teaser">{article.data.description}</p>
              <span class="related-card__link">Read article <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <CtaSection heading="Want personalised advice for your situation?" text="Every financial situation is different. Let's talk about yours." />

  <script slot="scripts">
    (function() {
      /* Reading progress bar */
      var progressBar = document.getElementById('readingProgress');
      var articleBody = document.getElementById('articleBody');

      window.addEventListener('scroll', function() {
        var rect = articleBody.getBoundingClientRect();
        var articleTop = rect.top + window.scrollY;
        var articleHeight = articleBody.offsetHeight;
        var scrolled = window.scrollY - articleTop;
        var progress = Math.min(Math.max(scrolled / articleHeight * 100, 0), 100);
        progressBar.style.width = progress + '%';
      }, { passive: true });

      /* Estimated read time */
      var text = articleBody.textContent || articleBody.innerText;
      var wordCount = text.trim().split(/\s+/).length;
      var minutes = Math.ceil(wordCount / 200);
      document.getElementById('readTime').textContent = minutes + ' min read';

    })();
  </script>
</BaseLayout>
