---
interface Props {
  heading?: string;
  text?: string;
}

const {
  heading = 'Schedule a free call',
  text = "A short phone call will give us both a chance to see if our expertise matches your needs."
} = Astro.props;
---

<section class="cta-section">
  <div class="container fade-up">
    <h2>{heading}</h2>
    <p>{text}</p>
    <a href="/contact/" class="btn btn--primary">Book a free call</a>
  </div>
</section>
