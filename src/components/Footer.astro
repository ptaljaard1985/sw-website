---
interface Props {
  showSocial?: boolean;
}

const { showSocial = false } = Astro.props;
---

<footer class="footer">
  <div class="footer__grid">
    <div class="footer__brand">
      <div class="footer__logo"><picture><source srcset="/logo.webp" type="image/webp"><img loading="lazy" src="/logo.png" alt="Simple Wealth" width="400" height="120"></picture></div>
      <p>Independent financial planning from Ballito on the KZN north coast. We align your wealth with your values, lifestyle, and long-term goals.</p>
      <p class="footer__fsp">Simple Wealth (Pty) Ltd is an authorised financial services provider. FSP no. 50637</p>
    </div>
    <div class="footer__nav">
      <p class="footer__heading">How we help</p>
      <a href="/investment-planning/">Investment planning</a>
      <a href="/risk-planning/">Risk planning</a>
      <a href="/estate-planning/">Estate planning</a>
      <a href="/tax-planning/">Tax planning</a>
    </div>
    <div class="footer__nav">
      <p class="footer__heading">Company</p>
      <a href="/about-you/">About you</a>
      <a href="/about-us/">About us</a>
      <a href="/knowledge-and-insight/">Knowledge and insight</a>
      <a href="/contact/">Contact</a>
    </div>
    <div class="footer__nav">
      <p class="footer__heading">Get in touch</p>
      <div class="footer__contact-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        <a href="https://maps.app.goo.gl/z5PbmNjmUYrW6vDD7" target="_blank" rel="noopener">Office 7.17, Workshop17, 7th Floor, Ballito Junction Regional Mall, Leonora Dr, Ballito, 4399</a>
      </div>
      <div class="footer__contact-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        <a href="mailto:info@simplewealth.co.za">info@simplewealth.co.za</a>
      </div>
      {showSocial && (
        <div class="footer__social">
          <a href="https://www.linkedin.com/in/ptaljaard/" target="_blank" rel="noopener" aria-label="LinkedIn"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg></a>
          <a href="https://www.pierretaljaard.com/" target="_blank" rel="noopener" aria-label="Personal website"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></a>
        </div>
      )}
    </div>
  </div>
  <div class="footer__bottom">
    <span>&copy; {new Date().getFullYear()} Simple Wealth. All rights reserved.</span>
    <div class="footer__legal">
      <a href="https://maps.app.goo.gl/z5PbmNjmUYrW6vDD7" target="_blank" rel="noopener">Google Maps</a>
      <a href="/documents/popi-statement.pdf" target="_blank" rel="noopener">POPI Statement</a>
      <a href="/documents/conflict-of-interest-policy.pdf" target="_blank" rel="noopener">Conflict of Interest Management Policy</a>
      <a href="/documents/complaints-resolution-policy.pdf" target="_blank" rel="noopener">Complaints Resolution Policy</a>
    </div>
  </div>
</footer>
